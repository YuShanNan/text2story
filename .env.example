# 通用模型配置（统一用于修正 / 分镜 / 提示词 / 优化）
MODEL_API_KEY=
MODEL_BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-chat

# 通用设置
# 0 表示无限重试；大于 0 表示单个 AI 步骤的最大尝试次数
MAX_RETRY=5
REQUEST_TIMEOUT=120
THINKING_ENABLED=false
SRT_THINKING=false
STORYBOARD_THINKING=false
OPTIMIZE_THINKING=false
VIDEO_THINKING=false
REASONING_EFFORT=high
SRT_REASONING_EFFORT=high
STORYBOARD_REASONING_EFFORT=high
OPTIMIZE_REASONING_EFFORT=high
VIDEO_REASONING_EFFORT=high
MAX_CHUNK_SIZE=15000
SRT_MAX_CHUNK_SIZE=1000
STORYBOARD_MAX_CHUNK_SIZE=500
